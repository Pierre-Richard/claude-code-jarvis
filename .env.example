# .env.example — Template public des variables d'environnement
#
# Ce fichier est un modèle sans valeurs réelles. Il peut être commité sur Git.
# Pour démarrer : copie ce fichier en '.env' et remplis tes vraies clés.
#   cp .env.example .env

# ─── IA ───────────────────────────────────────────────────────────────────────

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── PRODUCTIVITÉ ─────────────────────────────────────────────────────────────

NOTION_API_KEY=your_notion_integration_secret_here
NOTION_DATABASE_ID=your_notion_database_id_here

# ─── GOOGLE ───────────────────────────────────────────────────────────────────

GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# ─── DÉPLOIEMENT & INFRA ──────────────────────────────────────────────────────

VERCEL_TOKEN=your_vercel_token_here
GITHUB_TOKEN=your_github_personal_access_token_here

# ─── PAIEMENT ─────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=sk_live_or_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
